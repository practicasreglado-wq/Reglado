# Plantilla de variables de entorno para Inmobiliaria Reglados.
# Copia este archivo a `.env` (mismo directorio) y rellena los valores reales.
# NUNCA commitees el .env con valores reales: ya está en .gitignore.

# --- Entorno ---
# En desarrollo: local. En producción: production (o cualquier cosa != local).
# Afecta a los defaults de CORS: en local se aceptan localhost:5175 /
# 127.0.0.1:5175 automáticamente; en producción solo se aceptan los orígenes
# definidos en CORS_ALLOWED_ORIGINS.
APP_ENV=local

# --- JWT (debe coincidir con el JWT_SECRET de ApiLoging) ---
JWT_SECRET=

# --- Privacidad del mapa ---
# Clave usada para desplazar las coordenadas públicas del mapa (HMAC-SHA256
# con el id de la propiedad). Sin esta clave, un atacante que conozca el
# algoritmo podría invertir el offset y obtener la ubicación real.
# Genera una clave aleatoria larga (mínimo 32 chars), por ejemplo:
#   openssl rand -hex 32
# Si se deja vacío, el backend usa JWT_SECRET como fallback. Si ambos están
# vacíos, las coordenadas del mapa se devuelven como null (fail-closed).
PRIVACY_MAP_SECRET=

# --- Base de datos ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inmobiliaria
DB_USER=root
DB_PASS=

# --- Integración con Claude (procesamiento de emails entrantes) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Webhook de correos entrantes (CloudMailin u otro) ---
INBOUND_WEBHOOK_TOKEN=

# --- SMTP (correos transaccionales) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=PHPMailer::ENCRYPTION_STARTTLS
SMTP_FROM=
SMTP_FROM_NAME=Reglado Real Estate Inmobiliaria

# --- CORS ---
# En local: http://localhost:5175,http://127.0.0.1:5175
# En producción: la URL pública del frontend (sin barra final).
# IMPORTANTE: el código en backend/config/cors.php lee CORS_ALLOWED_ORIGINS,
# así que el nombre de la variable tiene que ser exactamente ese.
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175

# --- URL pública del frontend ---
# Se usa para construir enlaces en correos transaccionales (ej. "Acceder a mi
# panel" en el correo de aprobación de documentos). En producción debe ser la
# URL exacta de tu dominio sin barra final; en local puede dejarse vacío para
# que use el default http://localhost:5175.
FRONTEND_URL=http://localhost:5175

# --- Configuración de dominio ---
DEFAULT_OWNER_USER_ID=1
DOCUMENT_REVIEW_EMAIL=

# Bandeja del administrador para notificaciones generales (ej. solicitudes
# de promoción a usuario Premium). Puede coincidir con DOCUMENT_REVIEW_EMAIL
# o ser distinta si quieres separar destinatarios por tipo de aviso.
ADMIN_NOTIFICATIONS_EMAIL=

# --- Retención del log de auditoría (días) para el cron purge_audit_log.php ---
# Valor por defecto si no se define: 365
AUDIT_LOG_RETENTION_DAYS=365

# --- Cookie de sesión ---
# Ponlo a true SOLO en producción con HTTPS. En local (HTTP) debe quedar
# vacío o false, si no el navegador descarta la cookie y la sesión no persiste.
SESSION_COOKIE_SECURE=false
