<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Si el archivo o carpeta existe físicamente, NO redirigir (servirlo directamente)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. Todo lo demás se envía al index.html de Vue
  RewriteRule . /index.html [L]
</IfModule>
